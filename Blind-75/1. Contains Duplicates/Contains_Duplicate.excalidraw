      "isDeleted": false,
      "boundElements": [],
      "updated": 1783952163546,
      "link": null,
      "locked": false,
      "text": "Example 3: <the element can repeat multiple times>\n    nums = [1, 1, 1, 3, 3, 4, 3, 2, 4, 2]\n    answer = true\n    explanation = at least one value appears more than once.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Example 3: <the element can repeat multiple times>\n    nums = [1, 1, 1, 3, 3, 4, 3, 2, 4, 2]\n    answer = true\n    explanation = at least one value appears more than once.",
      "autoResize": true,
      "lineHeight": 1.25
    },

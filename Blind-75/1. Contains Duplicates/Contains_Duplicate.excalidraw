      "link": null,
      "locked": false,
      "text": "for i in range(len(nums)):\n    for j in range(i + 1, len(nums)):\n        if nums[i] == nums[j]:\n            return True\nreturn False // no duplicates found",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "for i in range(len(nums)):\n    for j in range(i + 1, len(nums)):\n        if nums[i] == nums[j]:\n            return True\nreturn False // no duplicates found",
      "autoResize": true,
      "lineHeight": 1.25
    },

      "seed": 1110607758,
      "version": 593,
      "versionNonce": 1789147534,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783937758789,
      "link": null,
      "locked": false,
      "text": "Example 2:\n    nums = [1, 2, 3, 4]\n    answer = false\n    explanation = every element is unique in the nums array",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Example 2:\n    nums = [1, 2, 3, 4]\n    answer = false\n    explanation = every element is unique in the nums array",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "k9GMHIc1D02k9kP3VB2YT",
      "type": "text",
      "x": 1518.500135656494,
      "y": 455.3858792874352,
      "width": 823.7877197265625,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",

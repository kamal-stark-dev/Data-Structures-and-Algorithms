      "updated": 1783935203112,
      "link": null,
      "locked": false,
      "text": "Given an integer array `nums`, return true if any value appears at least twice in the array, and return false if every element is distinct.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Given an integer array `nums`, return true if any value appears at least twice in the array, and return false if every element is distinct.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "oxR-NT6WpqaHt9PLj61PR",
      "type": "text",
      "x": 1521.080057933553,
      "y": 290.1417141527462,
      "width": 691.31982421875,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0Q",
      "roundness": null,
      "seed": 1685595934,
      "version": 288,
      "versionNonce": 435441810,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783937758789,
      "link": null,
      "locked": false,
      "text": "Example 1:\n    nums = [1, 2, 3, 1]\n    answer = true\n    explanation = 1 appears twice in the nums array",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Example 1:\n    nums = [1, 2, 3, 1]\n    answer = true\n    explanation = 1 appears twice in the nums array",
      "autoResize": true,
      "lineHeight": 1.25
    },
